# ============================================================
# 10x AI Agent - Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_WEBHOOK_SECRET=generate_a_random_string_here

# --- Authorization (single-tenant v1) ---
AUTHORIZED_TELEGRAM_USER_ID=8044736892

# --- Supabase ---
SUPABASE_URL=https://uydnzmshiwrkglsgruqa.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_from_supabase_dashboard

# --- Anthropic (used in Phase 2) ---
ANTHROPIC_API_KEY=your_claude_api_key
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# --- GHL (used in Phase 3) ---
GHL_PRIVATE_INTEGRATION_TOKEN=your_ghl_token
GHL_LOCATION_ID=your_ghl_subaccount_location_id

# --- Google OAuth (used in Phase 4) ---
GOOGLE_OAUTH_CLIENT_ID=your_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- App config ---
APP_ENV=development
LOG_LEVEL=INFO
PUBLIC_BASE_URL=http://localhost:8000